# Copy to .env and fill in your Supabase project values (Project Settings → API).
# The anon key is safe to expose to the browser; Row Level Security should protect your data.
#
# Optional: HOST=0.0.0.0 — listen on all interfaces (phone on same Wi‑Fi). Default is 127.0.0.1 (this PC only).

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
